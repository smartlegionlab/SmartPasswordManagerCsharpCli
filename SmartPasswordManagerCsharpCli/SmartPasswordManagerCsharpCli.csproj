<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>SmartPasswordManagerCsharpCli</AssemblyName>
    <RootNamespace>SmartPasswordManagerCsharpCli</RootNamespace>

    <Version>1.0.0</Version>
    <Company>Alexander Suvorov</Company>
    <Product>Smart Password Manager CLI</Product>
    <Copyright>BSD 3-Clause License</Copyright>
    <Description>Smart Password Manager CLI (C#)</Description>
    <RepositoryUrl>https://github.com/smartlegionlab/SmartPasswordManagerCsharpCli</RepositoryUrl>

    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>

</Project>